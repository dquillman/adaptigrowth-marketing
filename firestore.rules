rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
              isBootstrapUser();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isBootstrapUser() {
      return isAuthenticated() && request.auth.token.email == 'dquillman2112@gmail.com';
    }

    // ===== USERS (HARDENED) =====

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Admin can write anything (includes Cloud Functions via Admin SDK which bypasses rules)
      allow write: if isAdmin();

      // Owner can update but NOT modify protected billing/role fields
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny([
              'isPro', 'plan', 'trial', 'trialEndsAt', 'trialStartedAt',
              'trialLengthDays', 'trialConsumed', 'subscriptionStatus',
              'stripeCustomerId', 'role', 'testerOverride', 'testerExpiresAt',
              'accessLevel', 'access'
            ]);

      // Owner can create their own profile (edge cases; primary creation via Admin SDK)
      allow create: if isOwner(userId);

      // Subcollections (e.g. /users/{uid}/questionProgress, exam_attempts)
      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ===== QUIZ RUNS (NEW — was missing from both files) =====

    match /quizRuns/{userId}/runs/{runId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ===== USAGE EVENTS (TIGHTENED) =====

    match /usage_events/{eventId} {
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    // ===== QUIZ ATTEMPTS (from live — two rule blocks) =====

    // Legacy broad match (kept for backward compat)
    match /quizAttempts/{attemptId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // ===== EXAM CONTENT (Public Read, Admin Write) =====

    match /exams/{examId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exam_sets/{setId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /smart_questions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exam_questions/{examId}/items/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /exam_questions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===== EXAM ATTEMPTS (nested path from local) =====

    match /exam_attempts/{userId}/{attemptId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /exam_attempts/{attemptId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, write: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // ===== USER MASTERY =====

    match /userMastery/{docId} {
      allow read, write: if isAuthenticated() && docId.matches('^' + request.auth.uid + '_.*') || isAdmin();
    }

    // ===== STUDY PLANS =====

    match /study_plans/{planId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // ===== USER SESSIONS =====

    match /user_sessions/{sessionId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ===== APP CONFIG (Public Read, pre-auth) =====

    match /app_config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ===== SYSTEM CONFIG (Public Read, pre-auth for version enforcement) =====

    match /system_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== MARKETING ASSETS (Public Read for Landing Page) =====

    match /marketing_assets/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== APP-SCOPED COLLECTIONS =====

    match /apps/{appId} {
      allow read: if true;

      match /config/{docId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /sources/{docId} {
        allow read, write: if isAdmin();
      }

      match /audit/{docId} {
        allow read: if isAdmin();
        allow create: if isAdmin() && request.resource.data.adminUid == request.auth.uid;
      }
    }

    // ===== BUG REPORTING / ISSUES =====

    match /issues/{issueId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /reported_issues/{issueId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /issue_categories/{categoryId} {
      allow read, write: if isAdmin();
    }

    match /release_versions/{versionId} {
      allow read, write: if isAdmin();
    }

    // ===== FRICTION EVENTS (EC-130) =====

    match /friction_events/{eventId} {
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    // ===== CONVERSION INTENT (EC-111) =====

    match /conversion_intent/{eventId} {
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    // ===== CONVERSION EVENTS =====

    match /conversion_events/{event} {
      allow read: if isAdmin();
    }

    // ===== ADMIN-ONLY COLLECTIONS =====

    match /admin_audit/{docId} {
      allow read, write: if isAdmin();
    }

    match /admin_metrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    match /admin_config/{docId} {
      allow read, write: if isAdmin();
    }

    match /testers/{testerId} {
      allow read, write: if isAdmin();
    }

    match /examHealth/{docId} {
      allow read, write: if isAdmin();
    }

    match /system_metrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /exam_update_sources/{docId} {
      allow read, write: if isAdmin();
    }

    match /weekly_reviews/{reviewId} {
      allow read, write: if isAdmin();
    }

    match /founder_briefings/{briefingId} {
      allow read, write: if isAdmin();
    }

    match /decisions/{decisionId} {
      allow read, write: if isAdmin();
    }

    match /simulations/{simId} {
      allow read, write: if isAdmin();
    }

    match /billing_events_unresolved/{eventId} {
      allow read: if isAdmin();
    }

    match /admin_workflows/{userId}/{document=**} {
      allow read, write: if isAdmin();
    }

    match /admin_marketing_assets/{userId}/{document=**} {
      allow read, write: if isAdmin();
    }

    // ===== DEFAULT DENY =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
